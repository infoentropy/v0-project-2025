{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CTA Button",
  "type": "object",
  "required": ["label", "url"],
  "properties": {
    "label": {
      "type": "string",
      "description": "Button text (e.g. \"Shop Now\")"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Destination URL"
    },
    "bg_color": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$",
      "default": "#000000",
      "description": "Button background color"
    },
    "text_color": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$",
      "default": "#ffffff",
      "description": "Button label color"
    },
    "width": {
      "type": "string",
      "default": "200px",
      "description": "Button width (px or %)"
    },
    "border_radius": {
      "type": "string",
      "default": "4px",
      "description": "Corner rounding"
    },
    "font_size": {
      "type": "string",
      "default": "16px",
      "description": "Label font size"
    }
  }
}
