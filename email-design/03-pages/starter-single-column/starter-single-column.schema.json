{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Starter Single Column",
  "type": "object",
  "required": [
    "logo_url",
    "logo_alt",
    "hero_image_url",
    "hero_alt",
    "headline",
    "body_copy",
    "cta_label",
    "cta_url",
    "unsubscribe_url",
    "company_name",
    "company_address"
  ],
  "properties": {
    "logo_url": {
      "type": "string",
      "format": "uri",
      "description": "Hosted URL of the brand logo image"
    },
    "logo_alt": {
      "type": "string",
      "description": "Alt text for the logo"
    },
    "hero_image_url": {
      "type": "string",
      "format": "uri",
      "description": "Hosted URL of the hero image"
    },
    "hero_alt": {
      "type": "string",
      "description": "Alt text for the hero image"
    },
    "headline": {
      "type": "string",
      "description": "Main headline text"
    },
    "body_copy": {
      "type": "string",
      "description": "Body paragraph(s) — plain text or simple HTML"
    },
    "cta_label": {
      "type": "string",
      "description": "Button label"
    },
    "cta_url": {
      "type": "string",
      "format": "uri",
      "description": "Button destination URL"
    },
    "unsubscribe_url": {
      "type": "string",
      "format": "uri",
      "description": "Unsubscribe link"
    },
    "company_name": {
      "type": "string",
      "description": "Legal entity name for footer"
    },
    "company_address": {
      "type": "string",
      "description": "Physical mailing address for footer"
    }
  }
}
